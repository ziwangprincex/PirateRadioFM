# Copy this file to `.env` and fill in your credentials, or export the vars
# in your shell. `.env` is gitignored (only `.env.example` is committed).

# --- Spotify (optional; only needed for /spotify-* commands) ----------------
# 1. Create an app at https://developer.spotify.com/dashboard
# 2. Under "Redirect URIs" add EXACTLY: http://127.0.0.1:8888/callback
# 3. Copy the Client ID here.
# The redirect URL isn't actually reached — pirate-radio uses PKCE and asks you
# to paste the `code` query param back with /spotify-complete-login.
SPOTIFY_CLIENT_ID=
